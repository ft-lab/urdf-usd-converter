<?xml version="1.0"?>
<!-- Warn if capsule or quat_xyzw is being used and the URDF version is earlier than 1.1. -->
<robot name="warning_urdf_11_capsule_quatxyz" version="1.0">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.4 0.1"/>
      </geometry>
    </visual>
    <collision name="collision_box">
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.4 0.1"/>
      </geometry>
    </collision>
  </link>

  <link name="arm_link">
    <visual>
      <origin xyz="0.3 0 0.05" quat_xyzw="0 0.70710678 0 0.70710678"/>
      <geometry>
        <capsule radius="0.05" length="0.5"/>
      </geometry>
    </visual>
    <collision name="collision_capsule">
      <origin xyz="0.3 0 0.05" quat_xyzw="0 0.70710678 0 0.70710678"/>
      <geometry>
        <capsule radius="0.05" length="0.5"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_to_arm" type="fixed">
    <parent link="base_link"/>
    <child link="arm_link"/>
    <origin xyz="0 0 0.1" quat_xyzw="0 0 0 1"/>
  </joint>
</robot>
